# ---------------------------------------------------------------------------
# Azure Pricing Dashboard — runtime configuration (example)
# Copy to deploy/.env and fill with real values locally. DO NOT COMMIT secrets.
# ---------------------------------------------------------------------------

# Public hostname served over HTTPS (used by Caddy for the Let's Encrypt cert).
APP_DOMAIN=pricing.example.com

# Contact email for Let's Encrypt registration.
ACME_EMAIL=admin@example.com

# Cloudflare API token scoped to edit the zone's DNS records (DNS-01 challenge).
# Passed to the container as a SECURE environment variable — never commit the real value.
CLOUDFLARE_API_TOKEN=cf-replace-me

# Default display currency. Each price still keeps its own currency code.
DEFAULT_CURRENCY=USD

# Pricing cache TTL in seconds; also drives the "stale data" flag.
CACHE_TTL_SECONDS=3600

# Azure Retail Prices API (override only if needed).
RETAIL_PRICES_BASE_URL=https://prices.azure.com/api/retail/prices
RETAIL_PRICES_API_VERSION=2023-01-01-preview

# --- deploy.sh only (not read by the app) ---
# Resource group + region for all created resources.
RESOURCE_GROUP=azpricing-rg
LOCATION=eastus

# Azure Container Registry name (globally unique, alphanumeric).
ACR_NAME=azpricingacr

# Storage account (3-24 lowercase alphanumeric, globally unique) for Azure Files.
STORAGE_ACCOUNT=azpricingstore

# Container group name and public DNS label (the *.region.azurecontainer.io prefix).
CONTAINER_GROUP=azure-pricing
DNS_LABEL=azpricing-demo

# Optional overrides (sensible defaults applied in deploy.sh).
# APP_SHARE=appdata
# CADDY_SHARE=caddydata
# IMAGE_TAG=20260101000000
